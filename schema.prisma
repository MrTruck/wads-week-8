// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // The 'url' line has been removed from here
}

model Todo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  task      String
  completed Boolean  @default(false)
  userId    String
}